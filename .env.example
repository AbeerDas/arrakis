# ---------------------------------------------------------------------------
# Arrakis environment variables
# Copy to `.env` for local dev and set the same keys in your Vercel project.
# NEVER commit real values — only this example file is committed.
# ---------------------------------------------------------------------------

# Public base URL of the app (used for auth email redirects + OpenRouter attribution).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (Project Settings -> API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Not used by MVP scaffold (Drizzle handles DB), kept for future
# Supabase admin/auth operations. Keep it secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Database (Project Settings -> Database -> Connection string) ---
# Runtime: the POOLED transaction connection (port 6543) — works in serverless.
DATABASE_URL=postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# Migrations / drizzle-kit: the DIRECT connection (port 5432).
DIRECT_URL=postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# --- Email generator (OpenRouter; OpenAI-compatible gateway) ---
OPENROUTER_API_KEY=sk-or-...
# Default model slug; override to any model OpenRouter exposes.
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# --- Stripe (one-time unlock of verified contacts) ---
# Not provisioned yet — leave blank until you create the account.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# The one-time Price id for the verified-contacts unlock (placeholder for now).
STRIPE_PRICE_ID=

# --- Cron (nightly yc-oss refresh) ---
# Vercel Cron sends `Authorization: Bearer <CRON_SECRET>` automatically.
# Generate a random value, e.g. `openssl rand -hex 32`.
CRON_SECRET=

# --- Admin bootstrap ---
# This email is auto-granted is_admin on first sign-in.
ADMIN_EMAIL=abeerdas647@gmail.com

# --- GitHub signals (startup activity enrichment) ---
# Read-only is all we need. Prefer a fine-grained PAT with "Public repositories"
# read access (or a classic token with NO scopes). Used only to raise the API
# rate limit when reading public repo stats. Optional: without it we fall back to
# unauthenticated requests (60/hr).
GITHUB_TOKEN=
